        return Map.of(
                QUERY_AUDIT_ACTION_STATUS_ACTIVE, STATUS_TEXT_QUERY_AUDIT_ACTIVE,
                QUERY_AUDIT_ACTION_STATUS_DEPRECATED, STATUS_TEXT_QUERY_AUDIT_DEPRECATED,
                QUERY_AUDIT_CONVENTION_STATUS_EXTERNAL_ONLY, STATUS_TEXT_QUERY_AUDIT_EXTERNAL_ONLY
        );
    }

    private String queryAuditActionsConventionText(String lang) {
